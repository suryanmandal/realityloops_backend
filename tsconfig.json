{
  "compilerOptions": {
    "strict": true,
    "verbatimModuleSyntax": true,

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",

    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "lib": ["ES2022"],

    "skipLibCheck": true
  },
  "include": ["**/*"],
  "exclude": ["node_modules"]
}
